# Domain and TLS
DOMAIN=example.com
LETSENCRYPT_EMAIL=ops@example.com
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_STS_SECONDS=31536000
TRAEFIK_API_RATE_LIMIT_AVERAGE=100
TRAEFIK_API_RATE_LIMIT_BURST=200
MINIO_CONSOLE_HOST=minio.example.com

# Backend secrets
SECRET_KEY=change-this-secret-key
CHAT_MASTER_KEY=change-this-chat-master-key

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=rehub

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET_NAME=rehub-listing
CHAT_MINIO_BUCKET_NAME=rehub-chat
MINIO_SECURE=true

# App behavior
REQUIRE_EMAIL_VERIFICATION=true
SMS_DEBUG_MODE=false
FRONTEND_HOST=https://example.com
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
SENTRY_TEST_TOKEN=

# SMTP (optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false
EMAILS_FROM_EMAIL=no-reply@example.com
EMAILS_FROM_NAME=ReHub Platform

# Backup policy
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_HOURS=24
